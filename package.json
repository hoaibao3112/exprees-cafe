{
  "name": "exprees-cafe-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "npm run --prefix frontend dev",
    "dev:backend": "npm run --prefix backend start:dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "npm run --prefix frontend build",
    "build:backend": "npm run --prefix backend build",
    "install:all": "npm install --prefix frontend && npm install --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
